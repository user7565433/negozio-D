<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Negozio D — Vedène</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blanc:   #F8F5F0;
    --noir:    #0D0D0D;
    --or:      #C9A96E;
    --ardoise: #2A2A2A;
    --gris:    #888;
    --trans:   rgba(13,13,13,0.55);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--noir);
    color: var(--blanc);
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.4rem 3rem;
    background: linear-gradient(to bottom, rgba(13,13,13,0.85), transparent);
    backdrop-filter: blur(2px);
    transition: background 0.4s;
  }
  nav.scrolled { background: rgba(13,13,13,0.95); }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 300; letter-spacing: 0.25em;
    color: var(--blanc); text-decoration: none;
  }
  .nav-logo span { color: var(--or); }
  .nav-links { display: flex; gap: 2.2rem; list-style: none; }
  .nav-links a {
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(248,245,240,0.75); text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--or); }

  /* ── HERO VIDEO ── */
  #hero {
    position: relative; height: 100vh;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .hero-video-wrap {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero-video-wrap video {
    width: 100%; height: 100%; object-fit: cover;
    filter: brightness(0.55);
  }
  /* Fallback gradient si pas de vidéo */
  .hero-video-wrap::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(13,13,13,0.4) 70%,
      var(--noir) 100%
    );
  }
  /* Simulated fashion video with CSS animation */
  .hero-canvas {
    position: absolute; inset: 0; z-index: 0;
    background: var(--ardoise);
    overflow: hidden;
  }
  .fabric-sweep {
    position: absolute; inset: 0;
    background: linear-gradient(135deg,
      #1a1a2e 0%, #16213e 25%, #0f3460 50%, #533483 75%, #1a1a2e 100%
    );
    background-size: 400% 400%;
    animation: fabricFlow 12s ease-in-out infinite;
    opacity: 0.8;
  }
  @keyframes fabricFlow {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .silhouette {
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 340px; height: 85%;
    background: linear-gradient(to top, rgba(13,13,13,0.9), transparent 60%);
  }
  .silhouette::before {
    content: '';
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 200px; height: 100%;
    background: linear-gradient(to top,
      rgba(201,169,110,0.15) 0%,
      rgba(201,169,110,0.05) 40%,
      transparent 70%
    );
    animation: silhouetteGlow 8s ease-in-out infinite alternate;
  }
  @keyframes silhouetteGlow {
    from { opacity: 0.4; transform: translateX(-50%) scaleX(0.9); }
    to   { opacity: 1;   transform: translateX(-50%) scaleX(1.1); }
  }

  /* Particules lumineuses */
  .particles { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .particle {
    position: absolute;
    width: 2px; height: 2px;
    background: var(--or);
    border-radius: 50%;
    animation: drift linear infinite;
    opacity: 0;
  }
  @keyframes drift {
    0%   { transform: translateY(100vh) translateX(0); opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(-20px) translateX(40px); opacity: 0; }
  }

  .hero-content {
    position: relative; z-index: 2;
    padding: 0 3rem 5rem;
    max-width: 700px;
  }
  .hero-eyebrow {
    font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--or); margin-bottom: 1.2rem;
    animation: fadeUp 1s 0.3s both;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 300; line-height: 1.0;
    letter-spacing: 0.04em;
    animation: fadeUp 1s 0.5s both;
  }
  .hero-title em { font-style: italic; color: var(--or); }
  .hero-sub {
    margin-top: 1.4rem;
    font-size: 0.85rem; letter-spacing: 0.08em; line-height: 1.9;
    color: rgba(248,245,240,0.7);
    max-width: 420px;
    animation: fadeUp 1s 0.7s both;
  }
  .hero-cta {
    margin-top: 2.2rem;
    display: inline-flex; align-items: center; gap: 1rem;
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--blanc); text-decoration: none;
    border-bottom: 1px solid var(--or); padding-bottom: 4px;
    transition: gap 0.3s, color 0.3s;
    animation: fadeUp 1s 0.9s both;
  }
  .hero-cta:hover { color: var(--or); gap: 1.5rem; }
  .hero-cta::after { content: '→'; }

  .scroll-hint {
    position: absolute; bottom: 2rem; right: 3rem; z-index: 2;
    writing-mode: vertical-rl;
    font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: rgba(248,245,240,0.4);
    display: flex; align-items: center; gap: 0.8rem;
    animation: fadeIn 2s 1.5s both;
  }
  .scroll-hint::before {
    content: '';
    display: block; width: 1px; height: 50px;
    background: linear-gradient(to bottom, transparent, var(--or));
    animation: scrollLine 2s 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%,100% { transform: scaleY(0); transform-origin: top; }
    50%      { transform: scaleY(1); transform-origin: top; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── SECTION BASE ── */
  section { padding: 7rem 3rem; }
  .section-label {
    font-size: 0.6rem; letter-spacing: 0.35em; text-transform: uppercase;
    color: var(--or); margin-bottom: 1rem; display: block;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 300; line-height: 1.15;
    max-width: 600px;
  }

  /* ── À PROPOS ── */
  #apropos {
    background: var(--ardoise);
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem;
    align-items: center;
  }
  .about-visual {
    position: relative; height: 520px; overflow: hidden;
    border-radius: 2px;
  }
  .about-visual-inner {
    width: 100%; height: 100%;
    background: linear-gradient(160deg, #1c1c3a 0%, #2d1b4e 50%, #1a2a1a 100%);
    animation: aboutShift 10s ease-in-out infinite alternate;
  }
  @keyframes aboutShift {
    from { background: linear-gradient(160deg, #1c1c3a 0%, #2d1b4e 50%, #1a2a1a 100%); }
    to   { background: linear-gradient(160deg, #1a2a1a 0%, #1c1c3a 50%, #3a1a2a 100%); }
  }
  .about-visual-inner::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent, transparent 2px,
      rgba(201,169,110,0.04) 2px, rgba(201,169,110,0.04) 4px
    );
  }
  .about-badge {
    position: absolute; bottom: -1px; right: -1px;
    background: var(--or); color: var(--noir);
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 0.8rem 1.4rem;
  }
  .about-text p {
    font-size: 0.95rem; line-height: 2.0; color: rgba(248,245,240,0.75);
    margin-top: 1.5rem;
  }
  .about-text p + p { margin-top: 1rem; }
  .about-stats {
    display: flex; gap: 3rem; margin-top: 2.5rem;
    border-top: 1px solid rgba(201,169,110,0.3);
    padding-top: 2rem;
  }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem; font-weight: 300; color: var(--or);
    display: block;
  }
  .stat-label {
    font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gris);
  }

  /* ── COLLECTIONS (immersive cards) ── */
  #collections { background: var(--noir); padding-bottom: 0; }
  .collections-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 3rem;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    grid-template-rows: auto;
    gap: 2px;
  }
  .col-card {
    position: relative; overflow: hidden;
    cursor: pointer;
  }
  .col-card:first-child { grid-row: span 2; height: 680px; }
  .col-card:not(:first-child) { height: 339px; }
  .col-bg {
    width: 100%; height: 100%;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .col-card:hover .col-bg { transform: scale(1.06); }
  .col-bg-1 {
    background: linear-gradient(135deg, #1a0a2e 0%, #2d0a4e 40%, #0a1a3e 100%);
    animation: bgPulse1 8s ease-in-out infinite alternate;
  }
  .col-bg-2 {
    background: linear-gradient(135deg, #0a1a0a 0%, #1a2a1a 50%, #0a0a1a 100%);
    animation: bgPulse2 10s ease-in-out infinite alternate;
  }
  .col-bg-3 {
    background: linear-gradient(135deg, #1a1a0a 0%, #2a1a0a 50%, #1a0a0a 100%);
    animation: bgPulse3 9s ease-in-out infinite alternate;
  }
  @keyframes bgPulse1 {
    from { filter: brightness(0.8) saturate(1.2); }
    to   { filter: brightness(1.1) saturate(1.5); }
  }
  @keyframes bgPulse2 {
    from { filter: brightness(0.9) saturate(1.0); }
    to   { filter: brightness(1.2) saturate(1.4); }
  }
  @keyframes bgPulse3 {
    from { filter: brightness(0.85) saturate(1.1); }
    to   { filter: brightness(1.1) saturate(1.6); }
  }
  /* Textile texture overlay */
  .col-bg::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent, transparent 3px,
      rgba(255,255,255,0.02) 3px, rgba(255,255,255,0.02) 6px
    ),
    repeating-linear-gradient(
      0deg,
      transparent, transparent 3px,
      rgba(255,255,255,0.015) 3px, rgba(255,255,255,0.015) 6px
    );
  }
  .col-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,13,13,0.85) 0%, transparent 50%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 2rem;
    transition: background 0.4s;
  }
  .col-card:hover .col-overlay {
    background: linear-gradient(to top, rgba(13,13,13,0.9) 0%, rgba(13,13,13,0.2) 100%);
  }
  .col-tag {
    font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--or); margin-bottom: 0.5rem;
  }
  .col-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 300; line-height: 1.2;
  }
  .col-card:first-child .col-name { font-size: 2.4rem; }
  .col-desc {
    font-size: 0.78rem; line-height: 1.7; color: rgba(248,245,240,0.65);
    margin-top: 0.6rem; max-width: 280px;
    opacity: 0; transform: translateY(10px);
    transition: opacity 0.4s 0.1s, transform 0.4s 0.1s;
  }
  .col-card:hover .col-desc { opacity: 1; transform: translateY(0); }
  .col-arrow {
    position: absolute; top: 1.5rem; right: 1.5rem;
    width: 36px; height: 36px;
    border: 1px solid rgba(201,169,110,0.5);
    display: flex; align-items: center; justify-content: center;
    color: var(--or); font-size: 0.9rem;
    opacity: 0; transform: rotate(-45deg);
    transition: opacity 0.4s, transform 0.4s;
  }
  .col-card:hover .col-arrow { opacity: 1; transform: rotate(0); }

  /* Effet lumineux mobile sur les cartes */
  .col-card::after {
    content: '';
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(
      circle at var(--mx, 50%) var(--my, 50%),
      rgba(201,169,110,0.12) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s;
  }
  .col-card:hover::after { opacity: 1; }

  /* ── AMBIANCE PARALLAX ── */
  #ambiance {
    position: relative; overflow: hidden;
    height: 60vh; min-height: 400px;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    padding: 0;
  }
  .ambiance-bg {
    position: absolute; inset: -10%;
    background: linear-gradient(120deg,
      #0a0a1a 0%, #1a0a2e 25%, #0a1a0a 50%, #1a1a0a 75%, #0a0a1a 100%
    );
    background-size: 300% 300%;
    animation: ambianceFlow 15s ease-in-out infinite;
  }
  @keyframes ambianceFlow {
    0%   { background-position: 0% 50%; transform: scale(1) rotate(0deg); }
    33%  { background-position: 50% 0%; transform: scale(1.05) rotate(0.5deg); }
    66%  { background-position: 100% 50%; transform: scale(1.02) rotate(-0.3deg); }
    100% { background-position: 0% 50%; transform: scale(1) rotate(0deg); }
  }
  .ambiance-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center,
      rgba(201,169,110,0.08) 0%, transparent 70%
    );
  }
  .ambiance-content {
    position: relative; z-index: 1;
    padding: 3rem;
  }
  .ambiance-content blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 4vw, 3rem);
    font-weight: 300; font-style: italic;
    line-height: 1.4; letter-spacing: 0.02em;
    color: rgba(248,245,240,0.9);
    max-width: 750px;
  }
  .ambiance-content cite {
    display: block; margin-top: 1.5rem;
    font-style: normal; font-family: 'Inter', sans-serif;
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--or);
  }

  /* ── UNIVERS / SERVICES ── */
  #univers {
    background: var(--ardoise);
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
  }
  .univers-left {
    padding: 5rem 4rem;
    border-right: 1px solid rgba(201,169,110,0.15);
  }
  .univers-right { padding: 5rem 4rem; }
  .service-list { margin-top: 3rem; }
  .service-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(248,245,240,0.08);
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; transition: padding 0.3s;
    group: true;
  }
  .service-item:hover { padding-left: 0.5rem; }
  .service-item-text h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 400;
  }
  .service-item-text p {
    font-size: 0.75rem; line-height: 1.7;
    color: rgba(248,245,240,0.5);
    margin-top: 0.3rem;
  }
  .service-item-icon {
    font-size: 0.8rem; color: var(--or);
    transition: transform 0.3s;
  }
  .service-item:hover .service-item-icon { transform: translateX(5px); }

  .brand-scroll {
    margin-top: 3rem;
    overflow: hidden;
    position: relative;
  }
  .brand-scroll::before, .brand-scroll::after {
    content: '';
    position: absolute; top: 0; bottom: 0;
    width: 40px; z-index: 1;
  }
  .brand-scroll::before { left: 0; background: linear-gradient(to right, var(--ardoise), transparent); }
  .brand-scroll::after  { right: 0; background: linear-gradient(to left, var(--ardoise), transparent); }
  .brand-track {
    display: flex; gap: 2.5rem;
    animation: brandRun 20s linear infinite;
    width: max-content;
  }
  @keyframes brandRun {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .brand-pill {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(248,245,240,0.35);
    border: 1px solid rgba(248,245,240,0.1);
    padding: 0.5rem 1.2rem; white-space: nowrap;
    border-radius: 50px;
  }

  /* ── CONTACT / CTA ── */
  #contact {
    background: var(--noir);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: start;
  }
  .contact-info h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 300; line-height: 1.2;
    margin-top: 1rem;
  }
  .contact-info h2 em { font-style: italic; color: var(--or); }
  .contact-details { margin-top: 3rem; display: flex; flex-direction: column; gap: 1.8rem; }
  .detail-row {
    display: flex; gap: 1.5rem; align-items: flex-start;
  }
  .detail-icon {
    font-size: 0.8rem; color: var(--or);
    margin-top: 0.15rem; flex-shrink: 0;
  }
  .detail-content label {
    display: block; font-size: 0.6rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--gris); margin-bottom: 0.3rem;
  }
  .detail-content span, .detail-content a {
    font-size: 0.9rem; color: rgba(248,245,240,0.85);
    text-decoration: none; display: block; line-height: 1.6;
  }
  .detail-content a:hover { color: var(--or); }

  /* Map placeholder */
  .map-container {
    position: relative; height: 460px; overflow: hidden;
    border: 1px solid rgba(201,169,110,0.15);
  }
  .map-inner {
    width: 100%; height: 100%;
    background: #111820;
    display: flex; align-items: center; justify-content: center;
  }
  iframe.real-map {
    width: 100%; height: 100%; border: none; filter: invert(0.9) hue-rotate(180deg) saturate(0.5);
  }
  .map-pin {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    z-index: 2;
    pointer-events: none;
  }
  .pin-dot {
    width: 12px; height: 12px;
    background: var(--or); border-radius: 50%;
    box-shadow: 0 0 0 6px rgba(201,169,110,0.2), 0 0 0 12px rgba(201,169,110,0.1);
    animation: pinPulse 2s ease-in-out infinite;
  }
  @keyframes pinPulse {
    0%,100% { box-shadow: 0 0 0 6px rgba(201,169,110,0.2), 0 0 0 12px rgba(201,169,110,0.1); }
    50%      { box-shadow: 0 0 0 10px rgba(201,169,110,0.3), 0 0 0 20px rgba(201,169,110,0.1); }
  }
  .pin-label {
    margin-top: 0.7rem;
    background: var(--ardoise); border: 1px solid rgba(201,169,110,0.3);
    padding: 0.4rem 0.9rem;
    font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--or);
  }
  .map-cta {
    position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    z-index: 3;
    background: var(--or); color: var(--noir);
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 0.7rem 1.8rem; text-decoration: none;
    transition: background 0.3s;
    white-space: nowrap;
  }
  .map-cta:hover { background: #d4b87e; }

  /* ── FOOTER ── */
  footer {
    background: var(--ardoise);
    padding: 2.5rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(201,169,110,0.12);
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; letter-spacing: 0.2em; font-weight: 300;
    color: rgba(248,245,240,0.5);
  }
  .footer-logo span { color: var(--or); }
  .footer-right {
    font-size: 0.62rem; letter-spacing: 0.1em;
    color: rgba(248,245,240,0.25);
    text-align: right;
  }

  /* ── SCROLL REVEAL ── */
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s, transform 0.8s; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
  .reveal-delay-3 { transition-delay: 0.45s; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    section { padding: 4rem 1.5rem; }
    #apropos, #univers, #contact { grid-template-columns: 1fr; gap: 3rem; }
    .collections-grid { grid-template-columns: 1fr; }
    .col-card:first-child { grid-row: auto; height: 420px; }
    .about-visual { height: 320px; }
    .univers-left { border-right: none; border-bottom: 1px solid rgba(201,169,110,0.15); padding: 3rem 1.5rem; }
